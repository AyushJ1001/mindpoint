{
  "name": "mindpoint",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "lightningcss": "1.31.1"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:mobile dev:backend",
    "dev:web": "node scripts/run-web-with-env.js dev",
    "dev:mobile": "cd apps/mobile && bun run start",
    "ios:mobile": "node scripts/run-mobile-with-env.js ios",
    "ios:mobile:build": "node scripts/run-mobile-with-env.js run:ios",
    "android:mobile": "node scripts/run-mobile-with-env.js android",
    "android:mobile:build": "node scripts/run-mobile-with-env.js run:android",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "node scripts/run-web-with-env.js build",
    "build:turbo": "turbo run build --filter=@mindpoint/web",
    "start": "node scripts/run-web-with-env.js start",
    "lint": "turbo run lint --filter=@mindpoint/web",
    "type-check": "npm-run-all type-check:web type-check:mobile type-check:backend",
    "type-check:web": "turbo run type-check --filter=@mindpoint/web",
    "type-check:mobile": "turbo run type-check --filter=@mindpoint/mobile",
    "type-check:backend": "tsc --project convex/tsconfig.json --noEmit",
    "test:email": "node test-resend-email.js",
    "test:email:direct": "node test-resend-direct.js",
    "test:admin-route-protection": "node scripts/test-admin-route-protection.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.12",
    "@hookform/resolvers": "^5.2.1",
    "@icons-pack/react-simple-icons": "^13.7.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-email/render": "^1.2.0",
    "@uploadthing/react": "^7.3.3",
    "@upstash/ratelimit": "^2.0.6",
    "@upstash/redis": "^1.35.3",
    "@vercel/analytics": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.23.0",
    "dotenv": "^17.2.1",
    "embla-carousel-react": "^8.6.0",
    "googleapis": "^156.0.0",
    "lucide-react": "^0.536.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.264.2",
    "posthog-node": "^5.8.4",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^9.1.0",
    "react-phone-number-input": "^3.4.12",
    "react-razorpay": "^3.0.1",
    "react-use-cart": "^1.14.0",
    "remark-gfm": "^4.0.1",
    "resend": "^5.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "uploadthing": "^7.7.4",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/eslint-plugin-next": "^15.2.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "turbo": "^2.8.17",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5"
  }
}
